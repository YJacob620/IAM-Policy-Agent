{
    "policy": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Effect": "Allow",
                "Action": "dynamodb:PutItem",
                "Resource": "arn:aws:dynamodb:us-east-1:123456789012:table/MyTable",
                "Condition": {
                    "DateGreaterThan": {
                        "aws:CurrentTime": "2026-01-01T00:00:00Z"
                    },
                    "DateLessThan": {
                        "aws:CurrentTime": "2026-12-31T23:59:59Z"
                    }
                }
            }
        ]
    }
}