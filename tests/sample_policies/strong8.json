{
    "policy": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Effect": "Allow",
                "Action": "sts:AssumeRole",
                "Resource": "arn:aws:iam::123456789012:role/DeploymentRole",
                "Condition": {
                    "StringEquals": {
                        "sts:ExternalId": "expected-external-id"
                    }
                }
            }
        ]
    }
}