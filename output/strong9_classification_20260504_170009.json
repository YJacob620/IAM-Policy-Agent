{
    "policy": {
        "Statement": [
            {
                "Action": [
                    "s3:ListBucket",
                    "s3:GetObject",
                    "s3:GetObjectVersion"
                ],
                "Condition": {
                    "Bool": {
                        "aws:MultiFactorAuthPresent": "true"
                    }
                },
                "Effect": "Allow",
                "Resource": [
                    "arn:aws:s3:::my-production-data-bucket",
                    "arn:aws:s3:::my-production-data-bucket/*"
                ],
                "Sid": "AllowListAndReadSpecificBucket"
            },
            {
                "Action": "s3:*",
                "Condition": {
                    "BoolIfExists": {
                        "aws:MultiFactorAuthPresent": "false"
                    }
                },
                "Effect": "Deny",
                "Resource": "arn:aws:s3:::my-production-data-bucket/*",
                "Sid": "ExplicitDenyWithoutMFA"
            }
        ],
        "Version": "2012-10-17"
    },
    "classification": "Strong",
    "reason": "The policy adheres to least privilege principles by using specific actions and resources in Allow statements, and includes a compensating MFA condition.",
    "findings": []
}
