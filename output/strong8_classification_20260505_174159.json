{
    "policy": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Effect": "Allow",
                "Action": "sts:AssumeRole",
                "Resource": "arn:aws:iam::123456789012:role/DeploymentRole",
                "Condition": {
                    "StringEquals": {
                        "sts:ExternalId": "expected-external-id"
                    }
                }
            }
        ]
    },
    "classification": "Strong",
    "reason": "The policy follows the principle of least privilege by restricting sts:AssumeRole to a specific resource and enforcing an ExternalID condition for cross-account security.",
    "findings": []
}
