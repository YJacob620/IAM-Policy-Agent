{
    "policy": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Effect": "Allow",
                "Action": "sqs:SendMessage",
                "Resource": "arn:aws:sqs:us-east-1:123456789012:my-queue"
            },
            {
                "Effect": "Allow",
                "Action": "sqs:GetQueueAttributes",
                "Resource": "arn:aws:sqs:us-east-1:123456789012:my-queue"
            }
        ]
    },
    "classification": "Strong",
    "reason": "The policy follows the principle of least privilege by restricting actions to specific SQS resources and avoiding wildcards.",
    "findings": []
}
